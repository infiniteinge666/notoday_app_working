{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "textarea[autocapitalize]"
        ]
      }
    ],
    "axe/structure": [
      "default",
      {
        "listitem": "off"
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "-webkit-text-size-adjust"
        ]
      }
    ],
    "axe/text-alternatives": "off",
    "css-prefix-order": "off",
    "meta-viewport": "off"
  }
}